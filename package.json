{
	"name": "andys-charts",
	"version": "1.1.0",
	"description": "A simple charting library visualizing plays per day for musical tracks, made out of React, TypeScript and SVG.",
	"author": "Andy Graulund <andy@graulund.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/graulund/andys-charts.git"
	},
	"keywords": [
		"react",
		"chart",
		"svg",
		"area-chart",
		"time-series",
		"music"
	],
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./style.css": "./dist/style.css",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.0.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.63.0",
		"vite": "^6.3.0",
		"vite-plugin-css-injected-by-js": "^3.5.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	},
	"scripts": {
		"start": "vite --config vite.legacy.config.ts",
		"build": "npm run build:lib && npm run build:legacy",
		"build:lib": "vite build",
		"build:legacy": "vite build --config vite.legacy.config.ts",
		"typecheck": "tsc --noEmit",
		"lint": "eslint ./src",
		"test": "npm run test:unit && npm run test:browser",
		"test:unit": "vitest run",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:package": "node scripts/package-smoke.mjs",
		"coverage": "vitest run --coverage",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run build:lib"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
