{
  "name": "andys-charts",
  "version": "1.0.0",
  "description": "A simple charting library visualizing plays per day for musical tracks, made out of React, TypeScript and SVG.",
  "author": "Andy Graulund <andy@graulund.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/graulund/andys-charts.git"
  },
  "keywords": [
    "react",
    "chart",
    "svg",
    "area-chart",
    "time-series",
    "music"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3-path": "^3.1.0"
  },
  "devDependencies": {
    "@storybook/addon-actions": "^6.5.12",
    "@storybook/addon-essentials": "^6.5.12",
    "@storybook/addon-interactions": "^6.5.12",
    "@storybook/addon-links": "^6.5.12",
    "@storybook/builder-webpack5": "^6.5.12",
    "@storybook/manager-webpack5": "^6.5.12",
    "@storybook/node-logger": "^6.5.12",
    "@storybook/preset-create-react-app": "^4.1.2",
    "@storybook/react": "^6.5.12",
    "@storybook/testing-library": "^0.0.13",
    "@storybook/theming": "^6.5.12",
    "@types/d3-path": "^3.1.0",
    "ajv": "^8.12.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "babel-plugin-named-exports-order": "^0.0.2",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.9.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^6.3.0",
    "vite-plugin-css-injected-by-js": "^3.5.0",
    "vite-plugin-dts": "^4.5.0",
    "webpack": "^5.74.0"
  },
  "scripts": {
    "start": "vite --config vite.legacy.config.ts",
    "build": "npm run build:lib && npm run build:legacy",
    "build:lib": "vite build",
    "build:legacy": "vite build --config vite.legacy.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "prepublishOnly": "npm run typecheck && npm run build:lib",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:react/jsx-runtime"
    ],
    "rules": {
      "prefer-const": [
        "error"
      ],
      "prefer-destructuring": [
        "error",
        {
          "array": false,
          "object": true
        },
        {
          "enforceForRenamedProperties": false
        }
      ],
      "eqeqeq": [
        "error",
        "smart"
      ],
      "semi": [
        "error",
        "always"
      ]
    },
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
